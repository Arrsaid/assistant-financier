# Supabase : Dashboard → Project Settings → API
# Base de données : Dashboard → Project Settings → Database → Connection string

# --- Supabase (Auth + API) ---

SUPABASE_URL=https://votre-ref-projet.supabase.co
SUPABASE_ANON_KEY=votre-cle-anon-publique
SUPABASE_SERVICE_ROLE_KEY=votre-cle-secrete-service-role

# --- Postgres (Alembic + accès direct à la base) ---

# Utilise la connexion DIRECTE (hôte : db.<ref>.supabase.co).
# N'utilise PAS l'URL du transaction pooler (pooler.supabase.com) — les migrations exigent une connexion session.
# Encode en URL les caractères spéciaux du mot de passe.
DATABASE_URL=postgresql://postgres:votre-mot-de-passe@db.votre-ref-projet.supabase.co:5432/postgres

# --- Mistral (nécessaire dès que la couche LLM / embeddings est branchée) ---

MISTRAL_API_KEY=votre-cle-api-mistral
MISTRAL_MODEL=mistral-large-latest
MISTRAL_EMBEDDING_MODEL=mistral-embed
MISTRAL_EMBEDDING_DIMENSIONS=1024

# --- Serveur ---

# Origines navigateur autorisées à appeler l'API (CORS), séparées par des virgules.
ALLOWED_ORIGINS=http://localhost:5173
